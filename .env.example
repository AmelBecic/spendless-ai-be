# ── Environment template ─────────────────────────────────────────────
# Copy to `.env` and fill real values. `.env` is git-ignored — NEVER commit it.

NODE_ENV=development
PORT=3000

# ── Postgres (Supabase) ──────────────────────────────────────────────
# Supabase dashboard → "Connect" → "ORMs" → "Prisma" (replace [YOUR-PASSWORD]).
DATABASE_URL=      # pooled connection (port 6543, ?pgbouncer=true)
DIRECT_URL=        # direct connection (port 5432) — used for migrations (SLAI-4)

# ── Supabase Auth / API  (needed from SLAI-6 onward) ─────────────────
SUPABASE_URL=          # Settings → Data API → Project URL — required to verify tokens
SUPABASE_ANON_KEY=     # Settings → API Keys → anon / publishable key
# Optional: defaults to <SUPABASE_URL>/auth/v1/.well-known/jwks.json. Set only
# to point at a non-standard JWKS endpoint.
SUPABASE_JWKS_URL=

# ── Anthropic API  (needed from SLAI-16 onward) ──────────────────────
# console.anthropic.com → API keys. Server-side only — this key must never be
# sent to a client. Unset → the profiling/suggestion agents cannot be built.
ANTHROPIC_API_KEY=

# ── Cost guardrails  (SLAI-19) ───────────────────────────────────────
# The refresh routes are the only endpoints where one request buys a paid
# completion, so they are metered per user. Per process instance, not shared —
# N instances allow N times the limit.
REFRESH_RATE_LIMIT=10              # requests per user per window (0 disables the routes)
REFRESH_RATE_LIMIT_WINDOW_SEC=3600 # window length in seconds

# The in-process daily refresh job. OFF by default — it spends money in the
# background, so running the app locally against a real key must be an opt-in.
DAILY_REFRESH_ENABLED=false
DAILY_REFRESH_INTERVAL_MINUTES=1440 # 1440 = once a day

# ── Integration tests (optional locally) ─────────────────────────────
# Disposable Postgres for integration tests — NEVER the real DB. Unset → the
# integration suites skip and `npm run test` runs only the unit tests. CI
# provides this via a Postgres service. Local example:
# TEST_DATABASE_URL=postgresql://test:test@localhost:5432/spendless_test
TEST_DATABASE_URL=
