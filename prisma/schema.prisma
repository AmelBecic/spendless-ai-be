// SpendLess persistence schema. The backend owns this — so the database is
// portable off Supabase later. Money is always Int cents + String currency;
// no Float on any money column.
//
// Access is exclusively through the Fastify backend, which connects as the table
// owner (and so bypasses RLS). The enable_rls migration turns on row-level
// security with no policies as defence-in-depth, so Supabase's PostgREST/anon
// role cannot reach per-user financial data with the public publishable key.
// NB: this is defence-in-depth, not a hard boundary — the owner role and any
// BYPASSRLS role (Supabase's service_role) are unaffected, so the service-role
// key must still be guarded like a secret and kept server-side.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL") // pooled (pgbouncer) — app runtime
  directUrl = env("DIRECT_URL") // direct — migrations
}

enum Cadence {
  weekly
  monthly
  yearly
}

enum SuggestionStatus {
  new
  dismissed
  applied
}

/// Which agent a recorded pass belongs to.
enum AgentRunKind {
  profile
  suggestions
}

/// Per-user settings, mirrored from Supabase auth.users (userId = auth.users.id).
model UserProfile {
  userId             String   @id @db.Uuid
  currency           String   @default("EUR")
  timezone           String   @default("UTC")
  monthlyIncomeCents Int?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  fixedExpenses    FixedExpense[]
  transactions     Transaction[]
  profileSummaries ProfileSummary[]
  suggestions      Suggestion[]
  agentRuns        AgentRun[]

  @@map("user_profiles")
}

/// Records THAT an agent pass ran for a user on a day, independently of whether
/// it produced any output.
///
/// The suggestion loop's day-guard used to key on the rows it wrote, which never
/// fires for a pass that legitimately produces nothing: the user with the
/// emptiest ledger — the likeliest to yield no suggestions — was the one paying
/// for a completion on every single retry. A row here is written whether the pass
/// wrote ten suggestions or none, so "have we already run today?" stops being a
/// question about output.
model AgentRun {
  id        String       @id @default(uuid()) @db.Uuid
  userId    String       @db.Uuid
  kind      AgentRunKind
  asOfDate  DateTime     @db.Date
  createdAt DateTime     @default(now())

  user UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  /// One pass per user per kind per day — the guard reads this key directly, and
  /// it is what makes a concurrent second pass a constraint violation rather than
  /// a duplicate completion.
  @@unique([userId, kind, asOfDate])
  @@map("agent_runs")
}

model Category {
  id        String   @id @default(uuid()) @db.Uuid
  key       String   @unique
  label     String
  createdAt DateTime @default(now())

  fixedExpenses FixedExpense[]
  transactions  Transaction[]
  suggestions   Suggestion[]

  @@map("categories")
}

/// A recurring monthly/weekly/yearly commitment (rent, subscriptions…).
model FixedExpense {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  label       String
  categoryId  String   @db.Uuid
  amountCents Int
  currency    String
  cadence     Cadence
  active      Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user     UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  category Category    @relation(fields: [categoryId], references: [id])

  @@index([userId])
  @@index([categoryId])
  @@map("fixed_expenses")
}

/// A single day-to-day spend event — the stream the profile is built from.
model Transaction {
  id          String   @id @default(uuid()) @db.Uuid
  userId      String   @db.Uuid
  amountCents Int
  currency    String
  categoryId  String   @db.Uuid
  merchant    String?
  note        String?
  occurredAt  DateTime
  createdAt   DateTime @default(now())

  user     UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  category Category    @relation(fields: [categoryId], references: [id])

  @@index([userId, occurredAt])
  /// The scheduler's "has anything been entered since we last looked?" probe runs
  /// once per user per run and filters on `createdAt`, which the `occurredAt`
  /// index cannot serve — a backdated row sorts by when it happened, not by when
  /// it was typed in. Without this the daily job seq-scans a user's whole history
  /// to decide it has nothing to do.
  @@index([userId, createdAt])
  @@index([categoryId])
  @@map("transactions")
}

/// The AI-maintained summary of a user's financial profile — one per user per day
/// (the writer upserts on the (userId, asOfDate) unique key).
model ProfileSummary {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @db.Uuid
  asOfDate  DateTime @db.Date
  summary   Json
  narrative String
  model     String
  createdAt DateTime @default(now())

  user UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)

  @@unique([userId, asOfDate])
  @@map("profile_summaries")
}

/// A grounded, cited savings suggestion. Savings amount is Int cents + currency.
model Suggestion {
  id                     String           @id @default(uuid()) @db.Uuid
  userId                 String           @db.Uuid
  asOfDate               DateTime         @db.Date
  text                   String
  categoryId             String?          @db.Uuid
  estMonthlySavingsCents Int
  currency               String
  rationale              String
  sourceRefs             Json
  status                 SuggestionStatus @default(new)
  createdAt              DateTime         @default(now())

  user     UserProfile @relation(fields: [userId], references: [userId], onDelete: Cascade)
  category Category?   @relation(fields: [categoryId], references: [id])

  @@index([userId, asOfDate])
  @@index([categoryId])
  @@map("suggestions")
}
